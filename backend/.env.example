# Server
PORT=5000
NODE_ENV=development

# Client origin for CORS
CLIENT_URL=http://localhost:5173

# AI Provider Configuration
# Supported: mock | gemini | claude | openai | ollama | deepseek
LLM_PROVIDER=mock

# API Key (leave empty until an AI provider is integrated)
LLM_API_KEY=

# Optional: Provider-specific base URL (e.g., for Ollama self-hosted)
LLM_BASE_URL=

# OpenRouter Configuration
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
